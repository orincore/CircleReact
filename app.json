{
  "expo": {
    "name": "Circle",
    "slug": "Circle",
    "version": "9.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "circle",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "buildNumber": "110",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsArbitraryLoadsInWebContent": true
        },
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Circle uses your location to find nearby matches and improve your dating experience, even when the app is closed.",
        "NSLocationWhenInUseUsageDescription": "Circle uses your location to find nearby matches and improve your dating experience.",
        "NSPhotoLibraryUsageDescription": "Circle needs access to your photo library to save images and videos from chat messages.",
        "UIBackgroundModes": [
          "location",
          "location",
          "location",
          "location"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "UIApplicationSceneManifest": {
          "UIApplicationSupportsMultipleScenes": false,
          "UISceneConfigurations": {
            "UIWindowSceneSessionRoleApplication": [
              {
                "UISceneConfigurationName": "Default Configuration",
                "UISceneDelegateClassName": "$(PRODUCT_MODULE_NAME).SceneDelegate"
              }
            ]
          }
        }
      },
      "bundleIdentifier": "com.orincore.Circle",
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:circle.orincore.com",
        "applinks:www.circle.orincore.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#7C2B86",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "icon": "./assets/images/icon.png",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "circle.orincore.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "*.circle.orincore.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "com.android.vending.BILLING",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "predictiveBackGestureEnabled": false,
      "versionCode": 111,
      "package": "com.orincore.Circle",
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.orincore.Circle",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro",
      "name": "Circle",
      "shortName": "Circle",
      "description": "No Swiping Dating & Friendship App with AI-Powered Smart Matching",
      "themeColor": "#7C2B86",
      "backgroundColor": "#7C2B86",
      "lang": "en"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "useAndroidX": true,
            "enableJetifier": true,
            "forceAndroidX": true,
            "ndkVersion": "27.0.12077973",
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 24,
            "buildToolsVersion": "36.0.0",
            "extraProguardRules": "-keepattributes SourceFile,LineNumberTable\n-renamesourcefileattribute SourceFile\n-keep,allowobfuscation @interface com.facebook.react.bridge.ReactMethod\n-keep,allowobfuscation @interface com.facebook.react.uimanager.annotations.ReactProp\n-keepclassmembers class * {\n    @com.facebook.react.bridge.ReactMethod *;\n    @com.facebook.react.uimanager.annotations.ReactProp *;\n}\n-keep class org.webrtc.** { *; }\n-dontwarn org.webrtc.**\n-keep class com.airbnb.lottie.** { *; }\n-keep class com.google.android.gms.** { *; }\n-dontwarn com.google.android.gms.**\n-keep class com.google.firebase.** { *; }\n-dontwarn com.google.firebase.**\n-dontwarn okhttp3.**\n-dontwarn okio.**\n-keepnames class okhttp3.internal.publicsuffix.PublicSuffixDatabase\n-keep class com.facebook.hermes.unicode.** { *; }\n-keep class com.facebook.jni.** { *; }",
            "extraMavenRepos": [
              "https://www.jitpack.io"
            ],
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableProguardInReleaseBuilds": true,
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so",
                "**/libjsc.so"
              ]
            }
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-router",
      "expo-video",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Circle uses your location to find nearby matches and improve your dating experience, even when the app is closed.",
          "locationWhenInUsePermission": "Circle uses your location to find nearby matches and improve your dating experience."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#7C2B86",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "@react-native-firebase/app",
        {
          "android": {
            "googleServicesFile": "./google-services.json"
          },
          "ios": {
            "googleServicesFile": "./GoogleService-Info.plist"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#7C2B86",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#1F1147"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Circle needs access to your photo library to save images and videos from chat messages.",
          "savePhotosPermission": "Circle needs permission to save images and videos to your photo library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7904629558122562~8832481283",
          "iosAppId": "ca-app-pub-7904629558122562~2514886576"
        }
      ],
      "./app.plugin.js",
      "expo-status-bar",
      "@react-native-community/datetimepicker",
      "react-native-iap"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/c9234d97-8ff5-45bc-8f8f-8772ef0926a5"
    },
    "runtimeVersion": "9.0.0",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c9234d97-8ff5-45bc-8f8f-8772ef0926a5"
      }
    }
  }
}
