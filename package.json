{
  "name": "circle",
  "main": "expo-router/entry",
  "version": "2.1.1",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export --platform web --output-dir dist",
    "build:web": "EXPO_PUBLIC_PLATFORM=web expo export --platform web --output-dir dist",
    "build:amplify": "npm run build:web && npm run postbuild",
    "postbuild": "node scripts/postbuild.js",
    "vercel-build": "expo export --platform web --output-dir dist",
    "build:ota": "node ../scripts/build-ota-update.js",
    "export:android": "expo export --platform android --output-dir dist-android",
    "export:ios": "expo export --platform ios --output-dir dist-ios",
    "generate:icons": "node scripts/generate-icons.js",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "patch-package",
    "eas-build-post-install": "patch-package && node scripts/ensure-androidx.js"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "@expo/vector-icons": "^15.0.3",
    "@lottiefiles/dotlottie-react": "^0.13.5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-firebase/app": "^23.4.1",
    "@react-native-firebase/messaging": "^23.4.1",
    "@shopify/flash-list": "2.0.2",
    "@types/leaflet": "^1.9.20",
    "axios": "^1.12.2",
    "emojilib": "^4.0.3",
    "expo": "^56.0.12",
    "expo-auth-session": "~56.0.14",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.19",
    "expo-camera": "~56.0.8",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-image-manipulator": "~56.0.19",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-location": "~56.0.18",
    "expo-media-library": "~56.0.7",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-screen-capture": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-task-manager": "~56.0.19",
    "expo-updates": "~56.0.19",
    "expo-video": "~56.1.4",
    "expo-web-browser": "~56.0.5",
    "leaflet": "^1.9.4",
    "lottie-react-native": "~7.3.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-compressor": "^1.13.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-google-mobile-ads": "^15.8.0",
    "react-native-iap": "^15.3.6",
    "react-native-incall-manager": "^4.2.1",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-view-shot": "5.1.0",
    "react-native-web": "~0.21.0",
    "react-native-webrtc": "^124.0.4",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "react-native-youtube-iframe": "^2.4.1",
    "sharp": "^0.34.5",
    "unicode-emoji-json": "^0.9.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "@types/socket.io-client": "^1.4.36",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "fast-check": "^4.4.0",
    "jest": "~29.7.0",
    "patch-package": "^8.0.1",
    "react-test-renderer": "^19.1.0",
    "socket.io-client": "^4.8.1",
    "typescript": "~6.0.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-webrtc",
          "react-native-compressor",
          "react-native-incall-manager",
          "expo-modules-jsi"
        ],
        "listUnknownPackages": false
      }
    },
    "install": {
      "exclude": []
    }
  },
  "private": true
}
